{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["lib/**/*.js"],
  "exclude": ["lib/**/*.test.js", "node_modules", ".vibe", ".gsd"]
}
