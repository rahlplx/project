#!/usr/bin/env node
const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const ROOT = path.resolve(__dirname, '..');
let exitCode = 0;

// Gate 1: ESLint
const eslintBin = path.join(ROOT, 'node_modules', '.bin', 'eslint');
try {
  execSync(`"${eslintBin}" lib/ bin/ --no-eslintrc -c .eslintrc.js --quiet`, {
    cwd: ROOT, stdio: 'pipe', timeout: 30000, encoding: 'utf8',
  });
  console.log('[pre-commit] ✓ ESLint');
} catch (e) {
  console.error('[pre-commit] ✗ ESLint: lint errors found');
  console.error(e.stdout);
  exitCode = 1;
}

// Gate 2: YAML validity
try {
  const yaml = require('js-yaml');
  const raw = fs.readFileSync(path.join(ROOT, 'catalog/tools.yaml'), 'utf8');
  yaml.load(raw);
  console.log('[pre-commit] ✓ YAML valid');
} catch (e) {
  console.error('[pre-commit] ✗ YAML: ' + e.message);
  exitCode = 1;
}

process.exit(exitCode);
