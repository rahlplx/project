{
  "name": "@lablaunchpad/vibe-stack",
  "version": "2.9.0",
  "description": "45 AI agent skills for vibe coders — deploy, design, review, orchestrate. Works with Codex, OpenCode, Claude Code, Antigravity, and any MCP-compatible agent.",
  "main": "bin/vibe.js",
  "bin": {
    "vibe-stack": "bin/vibe.js"
  },
  "scripts": {
    "start": "node bin/vibe.js",
    "mcp": "node bin/vibe.js mcp",
    "vibe": "node bin/vibe.js",
    "vibe:help": "node bin/vibe.js help",
    "vibe:status": "node bin/vibe.js status",
    "vibe:harness": "node bin/vibe.js harness",
    "vibe:maintenance": "node bin/vibe.js maintenance",
    "vibe:telemetry": "node bin/vibe.js telemetry",
    "wizard": "node skills/setup/project-wizard/index.js",
    "test": "jest && node scripts/run-node-tests.js",
    "test:jest": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":75}}' && node scripts/run-node-tests.js",
    "test:node": "node scripts/run-node-tests.js",
    "test:node:coverage": "node --experimental-test-coverage --test lib/**/*.test.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --pretty",
    "format": "prettier --write .",
    "prepublishOnly": "npx jest --passWithNoTests --silent"
  },
  "keywords": [
    "vibe-coding",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "codex",
    "opencode",
    "claude-code",
    "no-code",
    "low-code",
    "prompt-engineering",
    "productivity",
    "development-tools"
  ],
  "author": "Vibe Stack Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahlplx/project.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "inquirer": "^8.2.6"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "\\.vibe",
      "\\.gsd"
    ],
    "testPathIgnorePatterns": [
      "node_modules",
      "\\.vibe",
      "\\.gsd",
      "/lib/"
    ]
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.2.0",
    "prettier": "^3.1.0",
    "typescript": "^6.0.3"
  }
}
